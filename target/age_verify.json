{"noir_version":"1.0.0-beta.19+74d6be658e1ad252f87943292ba09bdd4da80bd4","hash":"7687666358177421570","abi":{"parameters":[{"name":"birth_year","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"},{"name":"current_year","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"},{"name":"min_age","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"}],"return_type":null,"error_types":{"1998584279744703196":{"error_kind":"string","string":"attempt to subtract with overflow"}}},"bytecode":"","debug_symbols":"","file_map":{"51":{"source":"fn main(birth_year: u32, current_year: pub u32, min_age: pub u32) {\n    assert(birth_year <= current_year);\n    assert(birth_year >= current_year - 150);\n    let age = current_year - birth_year;\n    assert(age >= min_age);\n}\n\n#[test]\nfn test_valid_age() {\n    main(1990, 2026, 18);\n}\n\n#[test]\nfn test_exact_threshold() {\n    main(2008, 2026, 18);\n}\n","path":"/home/nemo/Coding/simple-zk-app/src/main.nr"}}}